# Jellyfin Prometheus Exporter

# Required
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=

# Optional
PORT=9711
SCRAPE_INTERVAL_MS=10000
LOG_LEVEL=info

# Request timeout per API call (ms)
REQUEST_TIMEOUT_MS=5000

# Retry: exponential backoff on transient failures
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=500

# Circuit breaker: stop requests after consecutive failures
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_MS=60000

# Optional: Bearer token auth on /metrics endpoint
# METRICS_TOKEN=

# Optional: expose `jellyfin_session_remote_address{user, remote_address}` for
# each active session. PII-adjacent — leave off unless you understand the
# privacy implications. Accepts true/false, 1/0, yes/no, on/off.
# EXPOSE_REMOTE_ADDRESS=false
